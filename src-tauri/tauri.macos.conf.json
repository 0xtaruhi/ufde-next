{
  "build": {
    "beforeBuildCommand": "./scripts/build-macos-sidecars.sh && pnpm build"
  },
  "bundle": {
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    },
    "resources": [
      "resource/**/*",
      "pthreadVC2.dll",
      "macos-bin/*",
      "macos-libs/*",
      "macos-plugins/platforms/*",
      "share/*",
      "share/fde/*"
    ]
  }
}
